CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# Keep only the initramfs decompressor exercised by the QEMU PGO workload.
CONFIG_RD_GZIP=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set

# The current boot-to-shell workload never exercises io_uring in runtime.
# CONFIG_IO_URING is not set

# These remain workload-validated size wins on the MPS2/QEMU target and
# should stay opt-in for this repo until a broader workload requires them.
# CONFIG_REGMAP is not set
# CONFIG_WATCHDOG is not set

# The QEMU workload never touches debugfs and only needs basic console output.
# Keep printk enabled, but drop validated debug-oriented features that add
# footprint without affecting the boot-to-shell flow.
# CONFIG_DEBUG_FS is not set
# CONFIG_PRINTK_TIME is not set

# These syscall-facing features show no workload-driven runtime use in the
# current QEMU profile and are safe to keep off for the validated boot-to-shell
# target unless a broader userspace workload needs them later.
# CONFIG_FHANDLE is not set
# CONFIG_ADVISE_SYSCALLS is not set
# CONFIG_MEMBARRIER is not set
# CONFIG_RSEQ is not set
# CONFIG_TIMERFD is not set
# CONFIG_SECCOMP is not set

# The validated QEMU workload does not exercise kernel keyrings or request_key.
# CONFIG_KEYS is not set

# The current MPS2/QEMU workload does not rely on syscon child devices.
# Keep the generic syscon MFD layer out so regmap/regcache can drop away if
# nothing else selects them.
# CONFIG_MFD_SYSCON is not set

# The validated workload does not require status LEDs or LED triggers.
# CONFIG_NEW_LEDS is not set

# Keep stack canary instrumentation out of the minimal boot-to-shell image.
# CONFIG_STACKPROTECTOR is not set
# CONFIG_STACKPROTECTOR_STRONG is not set

# The current initramfs ships the minimal device nodes needed by the
# validated workload, so devtmpfs is not required.
# CONFIG_DEVTMPFS is not set
# CONFIG_DEVTMPFS_MOUNT is not set

# The validated console-only workload does not use pseudo-terminals.
# CONFIG_UNIX98_PTYS is not set

# The validated workload does not access /proc/sys at all.
# CONFIG_PROC_SYSCTL is not set
